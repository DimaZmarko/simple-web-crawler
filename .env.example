# Postgres (compose uses these defaults; override for non-local)
POSTGRES_USER=crawler
POSTGRES_PASSWORD=crawler
POSTGRES_DB=crawler

# Backend
DATABASE_URL=postgres://crawler:crawler@db:5432/crawler?sslmode=disable
PORT=8080

# Frontend
API_URL=http://api:8080
NEXT_PUBLIC_API_URL=http://localhost:8080

# testcontainers-go on Colima (host-side, only if auto-detection fails)
# DOCKER_HOST=unix://${HOME}/.colima/default/docker.sock
# TESTCONTAINERS_DOCKER_SOCKET_OVERRIDE=/var/run/docker.sock
